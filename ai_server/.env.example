# ===== Providers =====
LLM_PROVIDER=mock                  # mock | watsonx
EMBEDDING_PROVIDER=mock            # mock | openai
STT_PROVIDER=mock                  # mock | watson
TTS_PROVIDER=mock                  # mock | azure
CAPTION_PROVIDER=mock              # mock | qwen
OBJECT_DETECTION_PROVIDER=mock     # mock | groundingdino
OCR_PROVIDER=mock                  # mock | paddleocr
SENTIMENT_PROVIDER=mock            # mock | kobert

# ===== IBM Cloud / watsonx.ai (LLM_PROVIDER=watsonx) =====
WATSONX_APIKEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_CHAT_MODEL_ID=ibm/granite-3-8b-instruct
WATSONX_EMBED_MODEL_ID=ibm/slate-125m-english-rtrvr

# ===== OpenAI Embedding (EMBEDDING_PROVIDER=openai) =====
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small

# ===== Internal security (SpringBoot -> FastAPI) =====
APP_API_KEY=local-dev-key

# ===== Vector store =====
CHROMA_DIR=./chroma_data
CHROMA_COLLECTION=woorizip

# ===== Tool execution (FastAPI -> Spring) =====
TOOL_EXECUTION_MODE=plan           # plan | execute
SPRING_BASE_URL=http://localhost:8080
SPRING_INTERNAL_API_KEY=internal-dev-key

# ===== Assistant(OpenAI/Azure OpenAI compatible) =====
AI_AGENT_ENDPOINT=
AI_AGENT_ENDPOINT_PATH=
AI_AGENT_MODEL=gpt-4o-mini
AI_AGENT_SYSTEM_PROMPT=
AI_AGENT_BASE_INFO=
AI_AGENT_AUTH_MODE=api_key
AI_AGENT_API_KEY=
AI_AGENT_BEARER_TOKEN=
AI_AGENT_API_VERSION=
AI_AGENT_TIMEOUT_MS=15000

# ===== Azure Speech TTS =====
AZURE_TTS_ENDPOINT=
AZURE_TTS_REGION=
AZURE_TTS_API_KEY=
AZURE_TTS_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3

# ===== Audio defaults =====
DEFAULT_TTS_VOICE=ko-KR-SunHiNeural
DEFAULT_AUDIO_FORMAT=wav
