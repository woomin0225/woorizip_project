+?import React, { useState } from 'react';
+import { useNavigate, useParams } from 'react-router-dom';
+import StepHeader from '../components/StepHeader';
+import { applyContract } from '../api/contractAPI';
+import { ROUTES } from '../../../shared/constants/routes';
+import styles from './ContractCreate.module.css';
+
+export default function ContractCreate() {
+  const navigate = useNavigate();
+  const { roomNo } = useParams();
+  const [form, setForm] = useState({ moveInDate: '', termMonths: 12 });
+  const handleChange = (e) => setForm((p) => ({ ...p, [e.target.name]: e.target.value }));
+
+  const handleSubmit = async (e) => {
+    e.preventDefault();
+    try {
+      await applyContract(roomNo, { moveInDate: form.moveInDate, termMonths: Number(form.termMonths) });
+      alert('입주 신청이 완료되었습니다.');
+      navigate(ROUTES.CONTRACT.LIST);
+    } catch (err) { alert(err.message || '입주 신청 실패'); }
+  };
+
+  return (
+    <div className={styles.page}>
+      <StepHeader title="입주 신청" description="방 번호 기준 계약 신청을 진행합니다." />
+      <form className={styles.form} onSubmit={handleSubmit}>
+        <label><span>방 번호</span><input value={roomNo || ''} disabled /></label>
+        <label><span>입주 희망일</span><input name="moveInDate" type="date" value={form.moveInDate} onChange={handleChange} required /></label>
+        <label><span>계약 기간(개월)</span><input name="termMonths" type="number" min="1" value={form.termMonths} onChange={handleChange} required /></label>
+        <button type="submit">입주 신청</button>
+      </form>
+    </div>
