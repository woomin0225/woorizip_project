+?import { getApiBaseUrl } from '../../../app/config/env';
+const API_BASE_URL = getApiBaseUrl();
+
+function authHeader() {
+  const token = localStorage.getItem('accessToken');
+  return token ? { Authorization: `Bearer ${token}` } : {};
+}
+
+async function request(path, { method = 'GET', body } = {}) {
+  const response = await fetch(`${API_BASE_URL}${path}`, {
+    method,
+    headers: { 'Content-Type': 'application/json', ...authHeader() },
+    ...(body ? { body: JSON.stringify(body) } : {}),
+  });
+  const raw = await response.text();
+  const payload = raw ? JSON.parse(raw) : null;
+  if (!response.ok) throw new Error(payload?.message || 'Tour API request failed');
+  return payload?.data ?? payload;
+}
+
+export async function createTour({ roomNo, visitDate, visitTime, message }) {
+  return request(`/api/tour/insert/${roomNo}`, { method: 'POST', body: { visitDate, visitTime, message } });
+}
+
+export async function updateTour({ tourNo, visitDate, visitTime, message }) {
+  return request(`/api/tour/update/${tourNo}`, { method: 'POST', body: { visitDate, visitTime, message } });
+}
+
+export async function getMyTours() {
+  const data = await request('/api/tour/list/me');
+  return Array.isArray(data) ? data : [];
+}
