@@ -1 +1,25 @@
-// placeholder
+?import { getApiBaseUrl } from '../../../app/config/env';
+const API_BASE_URL = getApiBaseUrl();
+
+function authHeader() {
+  const token = localStorage.getItem('accessToken');
+  return token ? { Authorization: `Bearer ${token}` } : {};
+}
+
+async function request(path, { method = 'GET', body } = {}) {
+  const response = await fetch(`${API_BASE_URL}${path}`, {
+    method,
+    headers: { 'Content-Type': 'application/json', ...authHeader() },
+    ...(body ? { body: JSON.stringify(body) } : {}),
+  });
+  const raw = await response.text();
+  const payload = raw ? JSON.parse(raw) : null;
+  if (!response.ok) throw new Error(payload?.message || 'Contract API request failed');
+  return payload?.data ?? payload;
+}
+
+export async function getMyContracts() { const data = await request('/api/contract/user/me'); return Array.isArray(data) ? data : []; }
+export async function getContract(contractNo) { return request(`/api/contract/${contractNo}`); }
+export async function applyContract(roomNo, payload) { return request(`/api/contract/insert/${roomNo}`, { method: 'POST', body: payload }); }
+export async function requestContractAmendment(originalContractNo, payload) { return request(`/api/contract/amendment/request/${originalContractNo}`, { method: 'POST', body: payload }); }
+export async function decideContractAmendment(amendmentNo, payload) { return request(`/api/contract/amendment/decide/${amendmentNo}`, { method: 'POST', body: payload }); }
